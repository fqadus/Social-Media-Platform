<!DOCTYPE html>
<html>
<head>
  <title>Sign Up</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f0f0f0;
      text-align: center;
      margin-top: 150px;
    }

    .box {
      background-color: white;
      padding: 20px;
      width: 250px;
      margin: auto;
      border: 1px solid #ccc;
    }

    input {
      width: 90%;
      padding: 8px;
      margin-top: 10px;
    }

    button {
      width: 95%;
      padding: 8px;
      margin-top: 10px;
    }
  </style>
</head>

<body>

  <div class="box">
    <h2>Sign Up</h2>

    <form action="/signup" method="POST">
      <input type="text" name="username" placeholder="Enter your name" required>
      <br>
      <button type="submit">Enter</button>
    </form>
  </div>

</body>
</html>