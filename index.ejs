<!DOCTYPE html>
<html>
<head>
  <title>Writing Feed</title>

  <style>
    /* overall page styling */
    body {
      font-family: Georgia, serif;
      background-color: #f4f1ed;
      color: #2f2f2f;
    }

    /* top header bar */
    .header {
      background: #ddd;
      padding: 10px;
      text-align: center;
      font-weight: bold;
      border-bottom: 1px solid #aaa;
    }

    /* main content container */
    .container {
      width: 600px;
      margin: auto;
      margin-top: 20px;
    }

    /* page title styling */
    h1 {
      text-align: center;
      font-weight: normal;
    }

    /* user info section */
    .nav {
      text-align: center;
      margin-bottom: 20px;
    }

    /* create post button box */
    .create-box {
      border: 1px solid #aaa;
      padding: 10px;
      margin-bottom: 20px;
      text-align: center;
      background: #eee;
    }

    /* individual post container */
    .post {
      border: 1px solid #ccc;
      padding: 10px;
      margin-bottom: 20px;
      background: #fff;
    }

    /* post header info */
    .post-header {
      font-size: 14px;
      margin-bottom: 5px;
    }

    /* timestamp styling */
    .time {
      font-size: 12px;
      color: gray;
      margin-left: 10px;
    }

    /* post content display */
    .post-content {
      margin-top: 5px;
      font-size: 18px;
      line-height: 1.5;
      word-break: break-word;
    }

    /* crossed-out text style */
    s {
      color: #444;
      text-decoration: line-through;
    }

    /* link styling */
    a {
      text-decoration: none;
      color: black;
    }

    /* button appearance */
    .button {
      display: inline-block;
      padding: 8px 12px;
      border: 1px solid black;
      background-color: white;
    }

    .button:hover {
      background-color: #eee;
    }
  </style>
</head>

<body>

  <!-- header section -->
  <div class="header">
    Writing Log
  </div>

  <div class="container">

    <h1>Public Notes</h1>

    <!-- current user display -->
    <div class="nav">
      <p><strong><%= user %></strong>'s entries</p>
    </div>

    <!-- create post button -->
    <div class="create-box">
      <a href="/create" class="button">Create a Post</a>
    </div>

    <!-- loop through all posts -->
    <% posts.forEach(function(post) { %>
      <% if (post && post.username) { %>

        <!-- single post block -->
        <div class="post">

          <div class="post-header">
            <strong><%= post.username %></strong>
            <span class="time"><%= post.time %></span>
          </div>

          <!-- post content with line breaks -->
          <div class="post-content">
            <%- post.content.replace(/\n/g, "<br>") %>
          </div>

        </div>

      <% } %>
    <% }) %>

  </div>

  <!-- temporary message on page load -->
  <script>
    window.onload = function() {
      let note = document.createElement("div");
      note.innerText = "Posts cannot be edited or deleted.";

      note.style.position = "fixed";
      note.style.bottom = "20px";
      note.style.left = "50%";
      note.style.transform = "translateX(-50%)";
      note.style.background = "#eee";
      note.style.padding = "10px";
      note.style.border = "1px solid #aaa";
      note.style.fontSize = "12px";

      document.body.appendChild(note);

      setTimeout(function() {
        note.remove();
      }, 4000);
    };
  </script>

</body>
</html>